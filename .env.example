TG_API_ID=12345678
TG_API_HASH=your_telegram_api_hash
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
TG_AUTH_MODE=phone
DEBUG_LOG=1

# Опционально: настройки подключения к Telegram через SOCKS5
# PROXY_HOST=127.0.0.1
# PROXY_PORT=10808
# PROXY_USERNAME=
# PROXY_PASSWORD=

# Для входа без SMS можно указать TG_AUTH_MODE=qr
