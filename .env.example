TG_API_ID=12345678
TG_API_HASH=your_telegram_api_hash
TG_AUTH_MODE=phone
DEBUG_LOG=1

# Необязательно: если хотите переиспользовать уже существующие WebPush-ключи и подписку
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# WEBPUSH_SUBSCRIPTION={"endpoint":"...","keys":{"p256dh":"...","auth":"..."}}

# Опционально: настройки подключения к Telegram через SOCKS5
# PROXY_HOST=127.0.0.1
# PROXY_PORT=10808
# PROXY_USERNAME=
# PROXY_PASSWORD=

# Для входа без SMS можно указать TG_AUTH_MODE=qr
